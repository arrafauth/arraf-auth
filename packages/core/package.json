{
  "name": "@arraf-auth/core",
  "version": "0.1.0",
  "description": "TypeScript-first authentication library built for the Saudi Arabia market",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": ["auth", "authentication", "otp", "saudi", "typescript"],
  "author": "arraf-auth",
  "license": "MIT",
  "homepage": "https://github.com/arrafauth/arraf-auth",
  "repository": {
    "type": "git",
    "url": "https://github.com/arrafauth/arraf-auth.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/arrafauth/arraf-auth/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "crypto": "^1.0.1",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
